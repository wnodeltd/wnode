# nodld Environment Configuration
# Copy to .env and fill in your values

# --- API Server ---
API_PORT=8080

# --- P2P Network ---
P2P_PORT=9000
# Comma-separated bootstrap peers (leave blank for LAN-only mDNS)
P2P_BOOTSTRAP_PEERS=

# --- Stripe (use test keys during development) ---
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_PLATFORM_ACCOUNT_ID=acct_REPLACE_ME

# --- Redis (optional, for persistent job queue) ---
REDIS_URL=redis://localhost:6379

# --- Logging ---
# Options: debug, info, warn, error
LOG_LEVEL=info
