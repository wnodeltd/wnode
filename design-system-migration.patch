+:root {
+  /* Core Colors - Obsidian & Cyan Baseline */
+  --nodl-bg: #000000;
+  --nodl-bg-nav: rgba(0, 0, 0, 0.4);
+  --nodl-card-bg: rgba(255, 255, 255, 0.02);
+  --nodl-card-bg-hover: rgba(255, 255, 255, 0.04);
+  --nodl-border: rgba(255, 255, 255, 0.1);
+  --nodl-border-hover: rgba(255, 255, 255, 0.2);
+  
+  --nodl-cyan: #22D3EE;
+  --nodl-cyan-dim: rgba(34, 211, 238, 0.1);
+  --nodl-cyan-border: rgba(34, 211, 238, 0.2);
+  
+  --nodl-purple: #a855f7;
+  --nodl-green: #22c55e;
+  --nodl-yellow: #eab308;
+  --nodl-red: #ef4444;
+
+  /* Text Colors */
+  --nodl-text-primary: #ffffff;
+  --nodl-text-secondary: #94a3b8; /* slate-400 */
+  --nodl-text-muted: #64748b; /* slate-500 */
+  --nodl-text-dim: #475569; /* slate-600 */
+
+  /* Spacing & Radii */
+  --nodl-radius: 5px;
+  --nodl-gap: 24px;
+}
+
+/* Utility Classes */
+.card-glass {
+  background-color: var(--nodl-card-bg);
+  border: 1px solid var(--nodl-border);
+  border-radius: var(--nodl-radius);
+  backdrop-filter: blur(8px);
+  transition: all 0.2s ease-in-out;
+}
+
+.card-glass:hover {
+  background-color: var(--nodl-card-bg-hover);
+  border-color: var(--nodl-border-hover);
+}
+
+.text-header-caps {
+  text-transform: uppercase;
+  letter-spacing: 0.2em;
+  font-weight: 700;
+  font-size: 10px;
+  color: var(--nodl-text-muted);
+}
+
+.text-value-lg {
+  font-size: 1.25rem; /* 20px */
+  font-weight: 400;
+  letter-spacing: -0.05em;
+  color: var(--nodl-text-primary);
+}
+
+.glow-cyan {
+  box-shadow: 0 0 15px rgba(34, 211, 238, 0.1);
+}
